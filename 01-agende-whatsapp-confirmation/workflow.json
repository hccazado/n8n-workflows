    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\n\nif (!allItems || allItems.length === 0) {\n    return [];\n}\n\nconst grouped = {};\n\nfor (const item of allItems) {\n    const a = item.json;\n\n    // Filtra apenas itens que possuem dados de agendamento válidos\n    if (!a.pacienteNome || !a.pacienteCelular || !a.idagendamento) continue;\n\n    const celular = String(a.pacienteCelular).replace(/\\D/g, '');\n    const key = celular; \n\n    if (!grouped[key]) {\n        const primeiroNomePaciente = a.pacienteNome.split(' ')[0];\n        \n        grouped[key] = {\n            nome: primeiroNomePaciente,\n            pacienteNome: a.pacienteNome,\n            pacienteCelular: celular,\n            usuarioResponsavel: a.usuarioResponsavel,\n            ids_lista: [],\n            inicioRaw: a.inicio, // Mantemos para o formatador de data\n            dataBase: \"\",\n            agendaPorProfissional: {} \n        };\n    }\n\n    // Processamento de Data e Hora\n    let horaStr = \"00:00\";\n    try {\n        const dataObjeto = new Date(a.inicio);\n        horaStr = dataObjeto.toLocaleTimeString('pt-BR', { \n            hour: '2-digit', \n            minute: '2-digit', \n            timeZone: 'America/Sao_Paulo' \n        });\n\n        if (!grouped[key].dataBase) {\n            const dia = String(dataObjeto.getDate()).padStart(2, '0');\n            const mes = String(dataObjeto.getMonth() + 1).padStart(2, '0');\n            const ano = String(dataObjeto.getFullYear()).slice(-2);\n            grouped[key].dataBase = `${dia}/${mes}/${ano}`;\n        }\n    } catch (e) {\n        horaStr = String(a.inicio).substring(11, 16);\n    }\n\n    const nomeCompletoProf = a.ProfissionalNome || \"Profissional\";\n    const primeiroNomeProf = nomeCompletoProf.trim().split(' ')[0];\n\n    if (!grouped[key].agendaPorProfissional[primeiroNomeProf]) {\n        grouped[key].agendaPorProfissional[primeiroNomeProf] = [];\n    }\n    grouped[key].agendaPorProfissional[primeiroNomeProf].push(horaStr);\n    \n    grouped[key].ids_lista.push(a.idagendamento);\n}\n\n// Formatação Final para o Webhook\nreturn Object.values(grouped).map(p => {\n    \n    const detalhesArray = Object.entries(p.agendaPorProfissional).map(([primeiroNome, horarios]) => {\n        const horasOrdenadas = [...new Set(horarios)].sort().join(' '); // Remove duplicados de hora e ordena\n        return `Dr(a) ${primeiroNome}: ${horasOrdenadas}`;\n    });\n\n    return {\n        json: {\n            nome: p.nome,\n            pacienteNome: p.pacienteNome,\n            pacienteCelular: p.pacienteCelular,\n            inicio: p.inicioRaw, // Enviado para o Webhook usar no Luxon/DateTime\n            data_agendamento: p.dataBase,\n            detalhes_profissionais: detalhesArray.join(', '), \n            ids_string: p.ids_lista.join(','),\n            usuarioResponsavel: p.usuarioResponsavel\n        }\n    };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
