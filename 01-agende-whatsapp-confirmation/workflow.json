    {
      "parameters": {
        "content": "**Checking schedule ID**",
        "height": 384,
        "width": 192
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        2464,
        -160
      ],
      "id": "45492832-3b38-46ac-ab85-f941cda1c080",
      "name": "Sticky Note5"
