        "jsonBody": "={\n  \"IdAgendamento\": \"{{ $json.ids_string }}\",\n  \"DataAgendamento\": \"{{ $json.data_agendamento }}\",\n  \"Telefone\": \"+55{{ $json.pacienteCelular.replace(/\\D/g, '') }}\",\n  \"Paciente\": \"{{ $json.pacienteNome }}\",\n  \"Nome\": \"{{ $json.nome }}\",\n  \"Profissional\": \"{{ $json.detalhes_profissionais }}\",\n  \"Responsavel\": \"{{ $json.usuarioResponsavel }}\"\n}",
